@inject RabbitMqService Rmq

<div class="fixed bottom-4 right-4 w-96 bg-base-100 border border-base-300 rounded-lg shadow-xl z-50">
    <div class="flex items-center justify-between px-4 py-3 border-b border-base-300">
        <h3 class="font-semibold text-sm">Publish Message</h3>
        <button @onclick="OnClose" class="btn btn-ghost btn-xs btn-square">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
    </div>

    <div class="p-4 space-y-3">
        <div class="form-control">
            <label class="label"><span class="label-text text-xs">Exchange</span></label>
            <input type="text" @bind="_exchange" placeholder="amq.default" class="input input-sm input-bordered w-full" />
        </div>
        <div class="form-control">
            <label class="label"><span class="label-text text-xs">Routing Key</span></label>
            <input type="text" @bind="_routingKey" placeholder="my.queue" class="input input-sm input-bordered w-full" />
        </div>
        <div class="form-control">
            <label class="label"><span class="label-text text-xs">Vhost</span></label>
            <input type="text" @bind="_vhost" placeholder="/" class="input input-sm input-bordered w-full" />
        </div>
        <div class="form-control">
            <label class="label"><span class="label-text text-xs">Payload</span></label>
            <textarea @bind="_payload" rows="4" class="textarea textarea-bordered w-full text-sm font-mono" placeholder="Message body..." />
        </div>
        <div class="flex items-center gap-2">
            <label class="label cursor-pointer gap-2">
                <input type="checkbox" @bind="_persistent" class="checkbox checkbox-sm" />
                <span class="label-text text-xs">Persistent</span>
            </label>
            <div class="flex-1"></div>
            <select @bind="_contentType" class="select select-sm select-bordered">
                <option value="text/plain">text/plain</option>
                <option value="application/json">application/json</option>
            </select>
        </div>
    </div>

    <div class="px-4 py-3 border-t border-base-300 flex justify-end gap-2">
        <button @onclick="OnClose" class="btn btn-ghost btn-sm">Cancel</button>
        <button @onclick="PublishAsync" class="btn btn-primary btn-sm" disabled="@_publishing">
            @if (_publishing)
            {
                <span class="loading loading-spinner loading-xs"></span>
            }
            Publish
        </button>
    </div>

    @if (_result is not null)
    {
        <div class="px-4 pb-3">
            <div class="@($"alert alert-sm {(_result == "Routed" ? "alert-success" : "alert-warning")}")">
                <span class="text-xs">@_result</span>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }

    private string _exchange = "";
    private string _routingKey = "";
    private string _vhost = "/";
    private string _payload = "";
    private string _contentType = "text/plain";
    private bool _persistent;
    private bool _publishing;
    private string? _result;

    private async Task PublishAsync()
    {
        _publishing = true;
        _result = null;
        try
        {
            var req = new PublishRequest(
                RoutingKey: _routingKey,
                Payload: _payload,
                PayloadEncoding: "string",
                Properties: new PublishProperties(
                    ContentType: _contentType,
                    DeliveryMode: _persistent ? 2 : 1
                )
            );

            var exchange = string.IsNullOrEmpty(_exchange) ? "" : _exchange;
            var res = await Rmq.PublishToExchangeAsync(_vhost, exchange, req);
            _result = res?.Routed == true ? "Routed" : "Not routed (no matching bindings)";
        }
        catch (Exception ex)
        {
            _result = $"Error: {ex.Message}";
        }
        finally
        {
            _publishing = false;
        }
    }
}
