# RabbitMQ connection settings (fallback if no active env in SQLite)
# Copy this file to .env.local and adjust for your environment.
# These are only used if no environment has been configured via the UI.

RABBITMQ_HOST=localhost
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_AMQP_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Optional: encrypt the SQLite database at rest.
# Set to any secret string; the key is SHA-256 hashed before use.
# STORAGE_ENCRYPTION_KEY=
